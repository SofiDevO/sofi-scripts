#!/bin/bash

# Script para reiniciar los servicios de RDP y solucionar conflictos de puerto con GNOME

echo "Deteniendo gnome-remote-desktop (sistema y usuario)..."
sudo systemctl stop gnome-remote-desktop 2>/dev/null
sudo systemctl disable gnome-remote-desktop 2>/dev/null
systemctl --user stop gnome-remote-desktop 2>/dev/null
systemctl --user disable gnome-remote-desktop 2>/dev/null

echo "Reiniciando servicios de xrdp..."
sudo systemctl restart xrdp
sudo systemctl restart xrdp-sesman

echo "-----------------------------------"
sudo systemctl status xrdp --no-pager
echo "-----------------------------------"
echo "Proceso completado. Intenta conectarte ahora."
